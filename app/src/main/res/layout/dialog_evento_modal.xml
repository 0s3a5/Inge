<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvModalTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Título del Evento"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvModalTipo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tipo: Pop-up"
        android:background="#E3F2FD"
        android:textColor="#1565C0"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvModalDireccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dirección"
        android:textSize="16sp"
        android:drawablePadding="8dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvModalDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Descripción detallada del evento aquí..."
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnModalCerrar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CERRAR VENTANA"
        android:backgroundTint="#D32F2F"
        android:textColor="@android:color/white"
        android:textStyle="bold"/>
</LinearLayout>