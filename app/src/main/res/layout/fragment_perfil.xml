<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/vistaLogin"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresar al Sistema"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2B5B84"
                android:layout_marginBottom="24dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ejemplo@voluntariado.cl"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:background="@android:color/white"
                android:layout_marginBottom="12dp"
                android:elevation="2dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:background="@android:color/white"
                android:layout_marginBottom="24dp"
                android:elevation="2dp"/>

            <Button
                android:id="@+id/btnIngresar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="INICIAR SESIÓN"
                android:textColor="@android:color/white"
                android:backgroundTint="#2B5B84"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvIrARegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta? Regístrate aquí"
                android:textColor="#2B5B84"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vistaRegistro"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registro de Voluntario"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2B5B84"
                android:layout_marginBottom="24dp"/>

            <EditText
                android:id="@+id/etRegistroNombre"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nombre completo"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:background="@android:color/white"
                android:layout_marginBottom="12dp"
                android:elevation="2dp"/>

            <EditText
                android:id="@+id/etRegistroEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="ejemplo@voluntariado.cl"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:background="@android:color/white"
                android:layout_marginBottom="12dp"
                android:elevation="2dp"/>

            <EditText
                android:id="@+id/etRegistroPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:background="@android:color/white"
                android:layout_marginBottom="12dp"
                android:elevation="2dp"/>

            <EditText
                android:id="@+id/etRegistroRut"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="RUT (ej: 201234567)"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:background="@android:color/white"
                android:layout_marginBottom="24dp"
                android:elevation="2dp"/>

            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="REGISTRARME"
                android:textColor="@android:color/white"
                android:backgroundTint="#2B5B84"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvIrALogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Ya tienes cuenta? Inicia Sesión"
                android:textColor="#2B5B84"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vistaPerfilLogueado"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tu Perfil"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#2B5B84"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvNombreUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando nombre..."
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvRolUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rol: Voluntario"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="28dp"/>

            <LinearLayout
                android:id="@+id/seccionUpgrade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E9ECEF"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Deseas publicar eventos?"
                    android:textStyle="bold"
                    android:textColor="#2B5B84"
                    android:textSize="15sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Para activar el rol de Organizador, ingresa el número de documento de tu cédula de identidad."
                    android:textSize="12sp"
                    android:textColor="#495057"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etDocUpgrade"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Ej: 987654321"
                    android:inputType="number"
                    android:paddingHorizontal="10dp"
                    android:background="@android:color/white"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSolicitarUpgrade"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:text="SOLICITAR PERMISO"
                    android:backgroundTint="#2B5B84"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="CERRAR SESIÓN"
                android:backgroundTint="#D32F2F"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>
        </LinearLayout>

    </FrameLayout>
</ScrollView>